# ─────────────────────────────────────────────
# Notion MCP Server – Environment Variables
# Copy this file to .env for local development
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Required: Your Notion Internal Integration Token
# Get it at: https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_your_integration_token_here

# Optional: A secret token to protect your MCP endpoint.
# ElevenLabs (and any client) must send: Authorization: Bearer <this value>
# Leave blank to run without auth (NOT recommended for public deployments)
MCP_AUTH_TOKEN=replace_with_a_long_random_secret

# Server port (Railway/Render will override this automatically via PORT)
PORT=3000

# Notion API version (only change if Notion releases a breaking version)
NOTION_VERSION=2022-06-28
